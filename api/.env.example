# Migrações: use um usuário com permissão para CREATE ROLE (ex.: superuser) na primeira vez,
# ou crie manualmente os papéis LigaDev e liga_app_rw. Senhas dos papéis de app defina com
# ALTER ROLE fora do repositório. A migration `20260408120000_postgres_roles_e_privilegios`
# aplica GRANTs em `public` para esses papéis.
# Exemplo local (InfoTIME — banco `liga_infotime`):
# DATABASE_URL=postgres://USUARIO:SENHA@localhost:5432/liga_infotime
# DATABASE_URL_MIGRATE=postgres://USUARIO_MIGRATE:SENHA@localhost:5432/liga_infotime
DATABASE_URL=postgres://USUARIO:SENHA@LOCALHOST:PORTA/liga_infotime
# Obrigatório no schema: mesmo banco, usuário com poder de migrar (ex.: superuser). @ na senha → %40 na URL.
DATABASE_URL_MIGRATE=postgres://USUARIO_MIGRATE:SENHA@LOCALHOST:PORTA/liga_infotime
API_PORT=3003
# Em dev no Windows, `localhost` costuma ligar só em IPv6 (::1). Use 127.0.0.1 para alinhar com API_URL no Next.
API_HOST=127.0.0.1

# URL do frontend — usada no CORS (pode listar várias origens separadas por vírgula)
WEB_URL=http://localhost:3004

# Chave secreta para geração da senha do dia (usuários suporte/implantacao)
SUPORTE_SECRET_KEY=troque-por-um-valor-seguro-em-producao
# Calendário usado para o "dia" da senha (IANA). Padrão America/Sao_Paulo (antes era implícito UTC).
# SENHA_DO_DIA_TIMEZONE=America/Sao_Paulo

# Id da tenacidade administrativa `liga.br` (string numérica, igual ao `tenantId` do JWT nesse domínio).
# API: RLS no modelo de tenacidade permite ver/editar todas as linhas para JWT suporte+implantacao neste tenant.
# Web: mesmo valor em `web/.env` para exibir o menu Implantação (`/api/auth/me`).
# LIGA_BR_TENACIDADE_ID=1

# Tokens JWT são assinados com `chave_jwt` por tenant no banco (não há secret global fixo na API).

# Ambiente de execução (afeta flag `secure` nos cookies JWT — use "production" em produção)
# NODE_ENV=production

# Redis para rate limiting distribuído (obrigatório em produção com múltiplas instâncias).
# Sem esta variável, o throttler usa memória local (adequado apenas para instância única).
# THROTTLER_REDIS_URL=redis://localhost:6379

# Redis para filas BullMQ (jobs financeiros: régua, score, etc.). Só sobe BullMQ se houver URL:
# use BULLMQ_REDIS_URL e/ou (para partilhar instância) THROTTLER_REDIS_URL. Sem ambos, filas ficam
# inativas e não há tentativa de ligação ao Redis (adequado em dev sem Redis).
# BULLMQ_REDIS_URL=redis://127.0.0.1:6379
# Forçar filas desligadas mesmo com URL (ex.: depuração):
# BULLMQ_DISABLED=1

# Limite específico de tentativas de login (endpoints /auth/login e /auth/login-confirm).
# Produção: mantenha valor baixo (ex.: 10). Desenvolvimento: pode elevar para evitar 429 durante testes.
# THROTTLE_LOGIN_LIMIT=10

# Janela de tempo do limite de login, em milissegundos (padrão 15 minutos).
# THROTTLE_LOGIN_TTL_MS=900000

# Healthcheck público: GET /health → { "status": "ok" }

# Next.js (web): em web/.env defina API_URL=http://127.0.0.1:3003 (BFF: login, logout, layout,
# POST /api/auth/suporte/registrar-acesso, etc.) — alinhado ao API_HOST em dev no Windows.
# Opcional: AUTH_STRICT=1 para falhar fechado se a API estiver inacessível no middleware.
