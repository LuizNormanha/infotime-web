  @@index([id_grupo_usuario], map: "idx_usuario_permissoes_grupo")
  @@index([id_tenacidade], map: "idx_usuario_permissoes_tenacidade")
  @@map("infotime_usuario_permissoes")
}

/// Personalização por perfil (grupo de usuário): JSON único (layout, menu, etc.).
model infotime_layout_formulario {
  id_layout_formulario  BigInt                @id @default(autoincrement())
  id_formulario         BigInt
  id_grupo_usuario      BigInt
  configuracao_json     String
  infotime_formulario    infotime_formulario    @relation(fields: [id_formulario], references: [id_formulario], onDelete: Restrict, onUpdate: Cascade)
  infotime_grupo_usuario infotime_grupo_usuario @relation(fields: [id_grupo_usuario], references: [id_grupo_usuario], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id_grupo_usuario, id_formulario])
  @@index([id_formulario])
  @@map("infotime_layout_formulario")
}
