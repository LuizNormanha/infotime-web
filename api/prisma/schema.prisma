/// Motor de metadados: definição de aplicação (listagem/formulário). id_tenacidade=0 = padrão global.
model infotime_aplicacao {
  id_aplicacao             BigInt                    @id @default(autoincrement())
  id_tenacidade            BigInt                    @default(0)
  id_usuario_auditoria     BigInt?
  codigo_aplicacao         String                    @db.VarChar(120)
  nome_aplicacao           String                    @db.VarChar(180)
  descricao_aplicacao      String?
  nome_tabela_principal    String                    @db.VarChar(120)
  nome_rota_frontend       String?                   @db.VarChar(200)
  nome_endpoint_backend    String?                   @db.VarChar(200)
  usa_listagem             Boolean                   @default(true)
  usa_formulario           Boolean                   @default(true)
  ativo                    Boolean                   @default(true)
  dica_aplicacao           String?
  observacao               String?
  nome_aplicacao_auditoria String?                   @db.VarChar(120)
  endereco_ip_auditoria    String?                   @db.VarChar(45)
  infotime_usuario          infotime_usuario?          @relation(fields: [id_usuario_auditoria], references: [id_usuario], onDelete: Restrict, onUpdate: Restrict, map: "fk_infotime_aplicacao_id_usuario_auditoria")
  infotime_aplicacao_campo  infotime_aplicacao_campo[]

  @@unique([id_tenacidade, codigo_aplicacao], map: "uq_infotime_aplicacao_01")
  @@index([id_tenacidade, codigo_aplicacao], map: "idx_infotime_aplicacao_01")
  @@index([ativo], map: "idx_infotime_aplicacao_02")
  @@map("infotime_aplicacao")
}

/// Metadados de campo (padrão). id_tenacidade=0 na linha base.
/// Tabela de overrides por tenacidade (`infotime_aplicacao_campo_tenacidade`) foi removida
/// pela migration `20260422130000_remove_infotime_aplicacao_campo_tenacidade`.
model infotime_aplicacao_campo {
  id_aplicacao_campo                    BigInt            @id @default(autoincrement())
  id_tenacidade                         BigInt            @default(0)
  id_aplicacao                          BigInt
  id_usuario_auditoria                  BigInt?
  codigo_campo                          String            @db.VarChar(120)
  nome_campo                            String            @db.VarChar(180)
  descricao_campo                       String?
  origem_campo                          String?           @db.VarChar(180)
  tipo_componente                       String            @db.VarChar(60)
  tipo_dado                             String            @db.VarChar(60)
  secao_formulario                      String?           @db.VarChar(100)
  aba_formulario                        String?           @db.VarChar(100)
  placeholder                           String?           @db.VarChar(200)
  mascara                               String?           @db.VarChar(80)
  dica_campo                            String?
  obrigatorio_padrao                    Boolean           @default(false)
  visivel_formulario_padrao             Boolean           @default(true)
  editavel_formulario_padrao            Boolean           @default(true)
  exibir_listagem_padrao                Boolean           @default(false)
  permite_filtro_padrao                 Boolean           @default(false)
  permite_ordenacao_padrao              Boolean           @default(false)
  fixo_listagem_padrao                  Boolean           @default(false)
  ordem_formulario_padrao               Int               @default(0)
  ordem_listagem_padrao                 Int               @default(0)
  participa_subtitulo_formulario_padrao Boolean           @default(false)
  ordem_subtitulo_formulario_padrao     Int               @default(0)
  largura_listagem_padrao               Int?
  alinhamento_listagem_padrao           String            @default("left") @db.VarChar(10)
  valor_padrao                          String?
  validacao_json                        Json              @default("{}")
  opcoes_json                           Json              @default("{}")
  ativo                                 Boolean           @default(true)
  nome_aplicacao_auditoria              String?           @db.VarChar(120)
  endereco_ip_auditoria                 String?           @db.VarChar(45)
  infotime_aplicacao                     infotime_aplicacao @relation(fields: [id_aplicacao], references: [id_aplicacao], onDelete: NoAction, onUpdate: NoAction, map: "fk_infotime_aplicacao_campo_01")

  @@unique([id_tenacidade, id_aplicacao, codigo_campo], map: "uq_infotime_aplicacao_campo_01")
  @@index([id_aplicacao, ativo], map: "idx_infotime_aplicacao_campo_01")
  @@index([id_aplicacao, ordem_formulario_padrao], map: "idx_infotime_aplicacao_campo_02")
  @@index([id_aplicacao, exibir_listagem_padrao, ordem_listagem_padrao], map: "idx_infotime_aplicacao_campo_03")
  @@index([id_tenacidade, id_aplicacao, codigo_campo], map: "idx_infotime_aplicacao_campo_04")
  @@map("infotime_aplicacao_campo")
}

