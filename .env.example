# Raiz / apps — ajuste conforme deploy

# Base existente `liga_infotime`; tabelas em `public`.
DATABASE_URL="postgresql://user:password@localhost:5432/liga_infotime?schema=public"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# API (Nest `@infotime/api`: prefix `/api/v1`; Fastify legado: `/api`)
API_HOST="0.0.0.0"
API_PORT="3333"
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"
REDIS_URL="redis://localhost:6379"

# Web (Vite)
# Deixe vazio para usar apenas o proxy em vite.config ( `/api` → API ).
# Ou URL completa incluindo prefixo Nest: http://localhost:3333/api/v1
VITE_API_URL=""
# Opcional: destino do proxy (padrão http://127.0.0.1:3333 no vite.config)
# VITE_PROXY_API=http://127.0.0.1:3333

# Storage (MinIO / S3)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="infotime"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_USE_SSL="false"
