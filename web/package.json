{
  "name": "@liga/template-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/next-dev-port.mjs",
    "build": "next build",
    "start": "node -e \"require('dotenv').config(); const p=process.env.WEB_PORT||3004; const {execSync}=require('child_process'); execSync('next start --port '+p,{stdio:'inherit',env:process.env})\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "next": "16.2.0",
    "next-intl": "^4.8.3",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "jsdom": "^29.1.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
