WEB_PORT=3004

# String de conexão ao banco (usada apenas pelo CLI Prisma via prisma.config.ts).
# Necessária somente se rodar `prisma generate`/`prisma migrate` a partir do diretório web/.
# Para runtime, a API Nest gerencia a conexão diretamente.
# DATABASE_URL=postgresql://user:pass@localhost:5432/liga_infotime

# URL da API Nest para o servidor Next (BFF, middleware, Route Handlers).
# Deve ser a origem que o processo Next alcança (porta da API, não WEB_PORT).
# Também alimenta o hostname opcional em allowedDevOrigins no next.config (via API_URL).
API_URL=http://localhost:3003

# Id da tenacidade `liga.br` (igual ao da API). Usado na API para RLS em `infolab_tenacidade`, não para o menu.
# LIGA_BR_TENACIDADE_ID=1

# AUTH_STRICT=true: se a API estiver inacessível, middleware e /api/auth/status não permitem sessão
# (redirect para login ou 503). Padrão (vazio/false): modo degradado (fail-open) para não bloquear o uso offline da UI.
# AUTH_STRICT=true

# Telemetria local opcional do script prisma-generate-dev (desligado por padrão).
# DEBUG_AGENT_TELEMETRY=1
# DEBUG_AGENT_INGEST_URL=http://127.0.0.1:7779/ingest/...

# IPs adicionais permitidos no HMR do Turbopack (hot reload)
ALLOWED_DEV_ORIGINS=192.168.1.70,172.20.144.1