-- Tabela: almoxarifado_usuario_atender
-- Entidade: almoxarifado
-- Origem: MySQL → PostgreSQL (schema liga_infotime)

-- liga_infotime.almoxarifado_usuario_atender  (origem MySQL: almoxarifadousuarioatender)
CREATE TABLE almoxarifado_usuario_atender (
  id_almoxarifado_usuario_atender bigint GENERATED BY DEFAULT AS IDENTITY NOT NULL,
  id_tenacidade bigint DEFAULT NULL,
  id_almoxarifado bigint DEFAULT NULL,
  id_usuario bigint DEFAULT NULL,
  PRIMARY KEY (id_almoxarifado_usuario_atender)
);
