-- Tabela: situacao_fornecedor
-- Entidade: fornecedor
-- Origem: MySQL → PostgreSQL (schema liga_infotime)

-- liga_infotime.situacao_fornecedor  (origem MySQL: situacaofornecedor)
CREATE TABLE situacao_fornecedor (
  id_situacao_fornecedor bigint GENERATED BY DEFAULT AS IDENTITY NOT NULL,
  descricao varchar(255) DEFAULT NULL,
  PRIMARY KEY (id_situacao_fornecedor)
);
