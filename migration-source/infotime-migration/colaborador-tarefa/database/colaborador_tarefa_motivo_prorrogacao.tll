-- Tabela: colaborador_tarefa_motivo_prorrogacao
-- Entidade: colaborador-tarefa
-- Origem: MySQL → PostgreSQL (schema liga_infotime)

-- liga_infotime.colaborador_tarefa_motivo_prorrogacao  (origem MySQL: colaboradortarefamotivoprorrogacao)
CREATE TABLE colaborador_tarefa_motivo_prorrogacao (
  id_colaborador_tarefa_motivo_prorrogacao bigint GENERATED BY DEFAULT AS IDENTITY NOT NULL,
  id_tenacidade bigint DEFAULT NULL,
  id_usuario_auditoria bigint DEFAULT NULL,
  nome varchar(255) DEFAULT NULL,
  endereco_ip_auditoria varchar(50) DEFAULT NULL,
  nome_aplicacao_auditoria varchar(255) DEFAULT NULL,
  PRIMARY KEY (id_colaborador_tarefa_motivo_prorrogacao)
);
