-- Tabela: almoxarifado_motivo_baixa
-- Entidade: almoxarifado-baixa
-- Origem: MySQL → PostgreSQL (schema liga_infotime)

-- liga_infotime.almoxarifado_motivo_baixa  (origem MySQL: almoxarifadomotivobaixa)
CREATE TABLE almoxarifado_motivo_baixa (
  id_almoxarifado_motivo_baixa bigint GENERATED BY DEFAULT AS IDENTITY NOT NULL,
  sigla varchar(30) DEFAULT NULL,
  descricao varchar(255) DEFAULT NULL,
  PRIMARY KEY (id_almoxarifado_motivo_baixa)
);
